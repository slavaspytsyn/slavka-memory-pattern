# === Required ===
# PostgreSQL connection string
DATABASE_URL=postgresql://smp_user:smp_pass_change_me@localhost:5432/smp_db

# === Embedding Provider ===
# Options: none (default, FTS only), openai, vertex
EMBEDDING_PROVIDER=none

# --- If using OpenAI ---
# OPENAI_API_KEY=sk-...

# --- If using Vertex AI ---
# GOOGLE_CLOUD_PROJECT=your-project-id
# VERTEX_AI_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/sa-key.json

# === Server Configuration ===
LISTEN_HOST=0.0.0.0
LISTEN_PORT=3100

# === Optional ===
# STATUS_FILE_PATH=~/.claude-memory/status.md
